# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/

# Environnements virtuels
.venv/
venv/

# Sphinx
docs/_build/

# Assets propres à un club (logo, banderoles) -- jamais versionnés dans le
# dépôt public partagé avec la FFTL, voir docs/architecture.md.
web/assets/club/

# Images de cibles -- à fournir par chaque club depuis une source dont il
# possède les droits (catalogue fournisseur, document FFTL/IFAA officiel...);
# pas incluses dans le dépôt public par prudence sur les droits d'auteur.
web/assets/targets/

# Bannières publicitaires / sponsors -- propres à chaque club, jamais
# versionnées (on garde uniquement le README qui explique leur usage).
web/assets/banners/*
!web/assets/banners/README.md

# Packs de sons : seul "classic" (généré par synthèse, libre de droits) est
# suivi par Git. N'importe quel autre dossier sous packs/ -- quel que soit
# son nom -- est un pack propre à un club et reste local, jamais versionné.
web/assets/sounds/packs/*
!web/assets/sounds/packs/classic/
!web/assets/sounds/packs/_custom/
web/assets/sounds/packs/_custom/*
!web/assets/sounds/packs/_custom/README.md

# OS / éditeurs
.DS_Store
Thumbs.db
*.swp
