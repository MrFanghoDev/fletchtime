# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/

# Environnements virtuels
.venv/
venv/

# Sphinx
docs/_build/

# Assets propres à un club (packs de sons perso, logo, banderoles) --
# jamais versionnés dans le dépôt public partagé avec la FFTL, voir
# docs/architecture.md.
sounds/packs/_custom/
web/assets/club/

# Images de cibles -- à fournir par chaque club depuis une source dont il
# possède les droits (catalogue fournisseur, document FFTL/IFAA officiel...);
# pas incluses dans le dépôt public par prudence sur les droits d'auteur.
web/assets/targets/

# Bannières publicitaires / sponsors -- propres à chaque club, jamais
# versionnées (on garde uniquement le README qui explique leur usage).
web/assets/banners/*
!web/assets/banners/README.md

# OS / éditeurs
.DS_Store
Thumbs.db
*.swp
